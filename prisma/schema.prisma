generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      String   @default("USER") // USER, ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]
  cart      CartItem[]
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  images      String   // Stored as JSON string of image URLs
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  stock       Int      @default(0)
  isExclusive Boolean  @default(false)
  isNew       Boolean  @default(false)
  rarity      String   @default("COMMON") // COMMON, RARE, ULTRA_RARE, VAULT_RELIC
  scale       String?  // e.g., 1:64
  brand       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems  OrderItem[]
  cartItems   CartItem[]
  inventoryLogs InventoryLog[]
}

model Category {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  status      String   @default("PENDING") // PENDING, PAID, SHIPPED, DELIVERED, CANCELLED
  total       Float
  shippingAddress String // JSON string
  paymentInfo String // JSON string (last 4, brand)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       OrderItem[]
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  priceAtPurchase Float
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id          String   @id @default(uuid())
  code        String   @unique
  discountType String  // PERCENTAGE, FIXED
  discountValue Float
  validFrom   DateTime
  validUntil  DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Deal {
  id          String   @id @default(uuid())
  name        String
  description String
  discountType String // PERCENTAGE, FIXED
  discountValue Float
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Drop {
  id          String   @id @default(uuid())
  name        String
  description String
  dropDate    DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryLog {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  change      Int      // e.g., +10, -5
  reason      String   // SALE, RESTOCK, ADJUSTMENT
  createdAt   DateTime @default(now())
}
